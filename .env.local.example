# TinyThreads AI - Environment Configuration

# =============================================
# DATABASE (Supabase PostgreSQL)
# =============================================
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# =============================================
# SUPABASE
# =============================================
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# =============================================
# OPENAI
# =============================================
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4.1"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# =============================================
# STRIPE
# =============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# =============================================
# APP
# =============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TinyThreads AI"

# =============================================
# FEATURE FLAGS
# =============================================
ENABLE_AI_RECOMMENDATIONS="true"
ENABLE_REALTIME_AUCTIONS="true"
ENABLE_PUSH_NOTIFICATIONS="true"